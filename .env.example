# SQLite database URL used by the CLI and Alembic.
LITSEARCH_DB_URL=sqlite:///./data/litsearch.db

# Directory reserved for later PDF downloads.
LITSEARCH_DOWNLOAD_DIR=./data/downloads

# Logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LITSEARCH_LOG_LEVEL=INFO

# Future HTTP client timeout in seconds.
LITSEARCH_HTTP_TIMEOUT_SECONDS=30

# Optional proxy URL. Passwords are masked in all safe output.
LITSEARCH_PROXY_URL=

# Contact email used as a fallback for community metadata sources.
LITSEARCH_CONTACT_EMAIL=

# Source-specific contact emails.
LITSEARCH_CROSSREF_EMAIL=
LITSEARCH_OPENALEX_EMAIL=
LITSEARCH_UNPAYWALL_EMAIL=

# Commercial source API keys. These are always masked in safe output.
# Scopus: https://dev.elsevier.com/
# IEEE Xplore and Web of Science are reserved for later API access.
LITSEARCH_IEEE_API_KEY=
LITSEARCH_SCOPUS_API_KEY=
LITSEARCH_SCOPUS_INST_TOKEN=
LITSEARCH_WOS_API_KEY=
